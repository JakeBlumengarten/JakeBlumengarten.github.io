source "https://rubygems.org"

# Use a version of Jekyll compatible with Ruby 4.0+
gem "jekyll", "~> 4.3.3"

# Explicitly add the standard GitHub Pages plugins 
group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.17"
  gem "jekyll-gist"
  gem "jekyll-include-cache"
  gem "jekyll-paginate"
  gem "jekyll-sitemap"
  gem "jekyll-redirect-from"
  gem "jemoji"
end

# Essential compatibility layers for Ruby 4.x
gem "webrick", "~> 1.8"
gem "base64", "~> 0.2.0"
gem "bigdecimal", "~> 3.1"
gem "csv", "~> 3.3"